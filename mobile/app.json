{
  "expo": {
    "name": "Gameboxd",
    "slug": "gameboxd",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "gameboxd",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0e0e10"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gameboxd.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0f0f"
      },
      "package": "com.gameboxd.app"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ]
  }
}
