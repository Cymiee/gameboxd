{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "types": ["react", "react-dom", "node", "vite/client"],
    "paths": {
      "@gameboxd/lib": ["../lib/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
